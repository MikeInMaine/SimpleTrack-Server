# LocTrack - your.domain.com
<VirtualHost *:80>
    ServerName your.domain.com
    Redirect permanent / https://your.domain.com/
</VirtualHost>

<IfModule mod_ssl.c>
<VirtualHost *:443>
    ServerName your.domain.com
    DocumentRoot /var/www/html/track
    DirectoryIndex index.php

    <Directory /var/www/html/track>
        Options -Indexes +FollowSymLinks
        AllowOverride None
        Require all granted

        # Password protection on the map view (index.php and api.php)
    </Directory>

    # track.php is NOT password protected - phones post here freely
    # Security comes from the device whitelist in config.php

    ErrorLog  ${APACHE_LOG_DIR}/track-error.log
    CustomLog ${APACHE_LOG_DIR}/track-access.log combined

    SSLEngine on
    SSLCertificateFile    /etc/letsencrypt/live/your.domain.com/fullchain.pem
    SSLCertificateKeyFile /etc/letsencrypt/live/your.domain.com/privkey.pem
    Include /etc/letsencrypt/options-ssl-apache.conf
</VirtualHost>
</IfModule>
